                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover/item:opacity-100 transition-opacity flex items-end p-6">
                        <span class="text-white font-medium">Download Our App</span>
                    </div>
                </div>
            </div>

            <div class="min-w-[85%] md:min-w-[45%] lg:min-w-[30%] snap-start">
                <div class="relative overflow-hidden rounded-2xl shadow-lg group/item">
                    <img src="/img/heli15_app.jpg" alt="Offer" class="w-full aspect-[16/9] object-cover transition-transform duration-500 group-hover/item:scale-105">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover/item:opacity-100 transition-opacity flex items-end p-6">
